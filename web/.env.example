# ===== Supabase（数据层）=====
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=          # 服务端用，勿暴露到前端

# ===== Chat 模型（ofox.ai Anthropic Messages 端点，原生 tool use + prompt caching，多模态）=====
CHAT_BASE_URL=                # ofox anthropic base，如 https://api.ofox.ai/anthropic（SDK 会打到 {base}/v1/messages）
CHAT_API_KEY=                 # ofox key（chat 与 embedding 可共用同一把）
CHAT_MODEL=                   # 默认聊天模型，如 anthropic/claude-sonnet-4.6（系统设置/对话框可覆盖）
SUMMARY_MODEL=                # RAG contextual 分块用的便宜模型，如 anthropic/claude-haiku-4.5

# ===== Embedding 模型（独立服务 —— cloudsway 不提供 embedding）=====
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIM=1536            # 必须与 schema.sql 的 vector(维度) 一致
